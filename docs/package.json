{
  "name": "dotfiles-docs",
  "private": true,
  "description": "Documentation site for my dotfiles.",
  "scripts": {
    "docs:lint": "bash ../scripts/markdownlint.sh",
    "docs:lint:fix": "bash ../scripts/markdownlint.sh --fix",
    "docs:prepare": "node scripts/generate-docs.mjs",
    "docs:dev": "npm run docs:prepare && vitepress dev",
    "docs:build": "npm run docs:lint && npm run docs:prepare && vitepress build",
    "docs:preview": "npm run docs:build && vitepress preview"
  },
  "devDependencies": {
    "vitepress": "2.0.0-alpha.17"
  }
}
