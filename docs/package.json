{
  "name": "dotfiles-docs",
  "private": true,
  "description": "Documentation site for my dotfiles.",
  "scripts": {
    "docs:lint": "markdownlint-cli2 --config ../.markdownlint-cli2.yaml \"../*.md\" \"../.agents/**/*.md\" \"src/**/*.md\"",
    "docs:lint:fix": "markdownlint-cli2 --fix --config ../.markdownlint-cli2.yaml \"../*.md\" \"../.agents/**/*.md\" \"src/**/*.md\"",
    "docs:prepare": "node scripts/generate-docs.mjs",
    "docs:dev": "npm run docs:prepare && vitepress dev",
    "docs:build": "npm run docs:lint && npm run docs:prepare && vitepress build",
    "docs:preview": "npm run docs:build && vitepress preview"
  },
  "devDependencies": {
    "markdownlint-cli2": "0.23.0",
    "vitepress": "2.0.0-alpha.17"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
